{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "repers.router.v1",
  "title": "RePERS router decision",
  "type": "object",
  "required": [
    "schema",
    "generated_at",
    "ok",
    "task",
    "repo_root",
    "signals",
    "permutation",
    "stages",
    "permutation_summary",
    "estimated_speedup_vs_naked",
    "reasons",
    "recommendation",
    "next_step",
    "errors"
  ],
  "properties": {
    "schema": {"const": "repers.router.v1"},
    "generated_at": {"type": "string", "description": "ISO 8601 UTC timestamp"},
    "ok": {"type": "boolean"},
    "task": {"type": "string"},
    "repo_root": {"type": "string"},
    "signals": {
      "type": "object",
      "required": ["repo_file_count", "domain_count", "estimated_task_files"],
      "properties": {
        "repo_file_count": {"type": ["integer", "null"]},
        "domain_count": {"type": "integer"},
        "estimated_task_files": {"type": ["integer", "null"]}
      }
    },
    "permutation": {
      "type": "string",
      "enum": ["skip", "R-only", "R-S", "R-E-R", "R-P-E-R", "R-P-E-R-S"]
    },
    "stages": {
      "type": "array",
      "items": {"type": "string", "enum": ["R", "P", "E", "S"]}
    },
    "permutation_summary": {"type": "string"},
    "estimated_speedup_vs_naked": {"type": "string"},
    "reasons": {"type": "array", "items": {"type": "string"}},
    "recommendation": {"type": "string"},
    "next_step": {
      "type": "object",
      "required": ["action", "command", "skill", "summary"],
      "properties": {
        "action": {
          "type": "string",
          "enum": ["skip_harness", "naked_loop", "research_only", "docs_only_ship", "invoke_bug_hunt_no_ship", "invoke_bug_hunt_full", "unknown"]
        },
        "command": {"type": ["string", "null"]},
        "skill": {"type": ["string", "null"]},
        "summary": {"type": "string"}
      }
    },
    "errors": {"type": "array", "items": {"type": "string"}}
  }
}
