{
  "schema": "repers.capability_registry.v1",
  "version": "0.2.0",
  "entries": [
    {
      "id": "route",
      "kind": "workflow",
      "name": "Task-to-Permutation Router",
      "summary": "Recommend which R-P-E-R-S permutation fits a task (skip / R-only / R-S / R-E-R / R-P-E-R / R-P-E-R-S) using keyword + repo-signal heuristics. Skips the harness for tasks too small to earn its weight.",
      "tags": [
        "router",
        "permutation",
        "decision-tree",
        "ceremony-budget",
        "skip-detection"
      ],
      "commands": [
        "python .repers/scripts/repers.py route --task \"<description>\" --json",
        "python .repers/scripts/repers.py route --task \"<description>\" --est-files <N> --json"
      ],
      "paths": [
        "scripts/repers.py",
        "scripts/router.py"
      ],
      "verification": [
        "python .repers/scripts/repers.py route --task \"fix typo in README\" --json",
        "python .repers/scripts/repers.py route --task \"migrate all pkg_resources to importlib.metadata across services/\" --est-files 12 --json"
      ]
    },
    {
      "id": "preflight",
      "kind": "workflow",
      "name": "Preflight Capability Discovery",
      "summary": "Search local files, structured capabilities, global skills, and optional CodeGraph evidence before adding reusable work.",
      "tags": [
        "preflight",
        "capability-discovery",
        "reuse",
        "codegraph",
        "ranking"
      ],
      "commands": [
        "python .repers/scripts/repers.py preflight --query \"<query>\" --refresh --json",
        "python .repers/scripts/repers.py preflight --query \"<query>\" --codegraph --json"
      ],
      "paths": [
        "scripts/repers.py",
        "scripts/research_index.py",
        "scripts/codegraph_support.py",
        "docs/contracts.md"
      ],
      "verification": [
        "python .repers/scripts/repers.py preflight --query \"capability registry\" --refresh --json"
      ]
    },
    {
      "id": "capability-registry",
      "kind": "registry",
      "name": "Local Capability Registry",
      "summary": "Canonical JSON inventory of reusable RePERS workflows, scripts, hooks, templates, and package gates.",
      "tags": [
        "capabilities",
        "registry",
        "json",
        "local-skills",
        "preflight"
      ],
      "commands": [
        "python .repers/scripts/repers.py capabilities --action list --json",
        "python .repers/scripts/repers.py capabilities --action search --query \"<query>\" --json",
        "python .repers/scripts/repers.py capabilities --action validate --json"
      ],
      "paths": [
        "capabilities/registry.json",
        "scripts/capability_registry.py",
        "scripts/research_index.py",
        "docs/contracts.md"
      ],
      "verification": [
        "python .repers/scripts/repers.py capabilities --action validate --json"
      ]
    },
    {
      "id": "orchestration-fixture",
      "kind": "harness",
      "name": "Deterministic Orchestration Fixture",
      "summary": "Proves conflict-safe worker dispatch, worker-command execution, local join verification, and review contracts.",
      "tags": [
        "fixture",
        "dag",
        "worker-command",
        "parallel",
        "review",
        "harness"
      ],
      "commands": [
        "python .repers/scripts/repers.py fixture --action prove --json"
      ],
      "paths": [
        "scripts/orchestration_fixture.py",
        "scripts/plan_runner.py",
        "scripts/reviewer.py",
        "tests/smoke_repers.py"
      ],
      "verification": [
        "python .repers/scripts/repers.py fixture --action prove --json"
      ]
    },
    {
      "id": "package-readiness",
      "kind": "shipping-gate",
      "name": "Package Readiness and Round Trip",
      "summary": "Builds a reusable RePERS archive with manifest, readiness sidecar, governance files, and round-trip install verification.",
      "tags": [
        "package",
        "readiness",
        "roundtrip",
        "install",
        "archive",
        "shipping"
      ],
      "commands": [
        "python .repers/scripts/repers.py package --output dist --verify-roundtrip --json",
        "python .repers/scripts/repers.py bundle-status --package --verify-roundtrip --json"
      ],
      "paths": [
        "scripts/package_repers.py",
        "scripts/install_repers.py",
        "docs/packaging.md",
        "README.md"
      ],
      "verification": [
        "python .repers/scripts/repers.py bundle-status --package --verify-roundtrip --json"
      ]
    },
    {
      "id": "install-hook",
      "kind": "hook",
      "name": "RePERS Pre-Commit Hook",
      "summary": "Installs a warn or strict pre-commit hook that runs RePERS audit before commits.",
      "tags": [
        "hook",
        "pre-commit",
        "audit",
        "install"
      ],
      "commands": [
        "python .repers/scripts/repers.py install-hook --hook-policy warn --json",
        "python .repers/scripts/repers.py install-hook --hook-policy strict --json"
      ],
      "paths": [
        "hooks/pre-commit",
        "scripts/install_repers.py",
        "scripts/repers.py"
      ],
      "verification": [
        "python .repers/scripts/repers.py audit"
      ]
    },
    {
      "id": "install-manifest-refresh",
      "kind": "maintenance",
      "name": "Installed Manifest Refresh",
      "summary": "Refreshes .repers/manifest.json after runtime edits and immediately verifies the installed bundle hashes.",
      "tags": [
        "install",
        "manifest",
        "verify",
        "maintenance",
        "package"
      ],
      "commands": [
        "python .repers/scripts/repers.py refresh-manifest --json",
        "python .repers/scripts/repers.py verify-install --json"
      ],
      "paths": [
        "scripts/repers.py",
        "scripts/install_repers.py",
        "manifest.json"
      ],
      "verification": [
        "python .repers/scripts/repers.py refresh-manifest --json",
        "python .repers/scripts/repers.py verify-install --json"
      ]
    },
    {
      "id": "task-dag",
      "kind": "workflow",
      "name": "Task DAG Planning and Execution",
      "summary": "Parses plan.md into plan.json, lists ready DAG steps, dispatches parallel worker prompts, and updates step status.",
      "tags": [
        "dag",
        "plan",
        "dispatch",
        "worker",
        "parallel",
        "execution"
      ],
      "commands": [
        "python .repers/scripts/repers.py plan --task <task> --json",
        "python .repers/scripts/repers.py run --task <task> --action dry-run --json",
        "python .repers/scripts/repers.py dispatch --task <task> --json"
      ],
      "paths": [
        "scripts/dag_engine.py",
        "scripts/plan_runner.py",
        "templates/plan.md",
        "docs/workflow.md"
      ],
      "verification": [
        "python .repers/scripts/repers.py fixture --action prove --json"
      ]
    },
    {
      "id": "review-release",
      "kind": "shipping-gate",
      "name": "Review, Shipping, and Release Gates",
      "summary": "Validates step result contracts, writes shipping evidence, and runs release gates over review, doctor, shipping, and audit.",
      "tags": [
        "review",
        "shipping",
        "release",
        "audit",
        "evidence"
      ],
      "commands": [
        "python .repers/scripts/repers.py review --task <task> --json",
        "python .repers/scripts/repers.py shipping --task <task> --json",
        "python .repers/scripts/repers.py release --task <task> --json"
      ],
      "paths": [
        "scripts/reviewer.py",
        "scripts/shipping.py",
        "scripts/release_gate.py",
        "docs/contracts.md"
      ],
      "verification": [
        "python .repers/scripts/repers.py fixture --action prove --json"
      ]
    },
    {
      "id": "receiver-governance",
      "kind": "docs",
      "name": "Open Source Receiver Governance",
      "summary": "Contributor, maintainer, support, security, roadmap, changelog, example, and CI surfaces expected in the package.",
      "tags": [
        "governance",
        "open-source",
        "docs",
        "ci",
        "examples"
      ],
      "commands": [
        "python .repers/scripts/repers.py bundle-status --package --verify-roundtrip --json"
      ],
      "paths": [
        "CONTRIBUTING.md",
        "SECURITY.md",
        "SUPPORT.md",
        "ROADMAP.md",
        "CHANGELOG.md",
        "MAINTAINERS.md",
        ".github/workflows/repers-smoke.yml",
        "examples/basic-task/README.md"
      ],
      "verification": [
        "python .repers/scripts/repers.py package --output dist --json"
      ]
    },
    {
      "id": "release-evidence",
      "kind": "shipping-gate",
      "name": "Release Evidence and Publish Readiness",
      "summary": "Generates a machine-readable publish-readiness artifact with package, governance, capability registry, and git branch/commit/remote state.",
      "tags": [
        "release",
        "publish",
        "evidence",
        "provenance",
        "branch",
        "commit",
        "pr",
        "package"
      ],
      "commands": [
        "python .repers/scripts/repers.py release-evidence --json",
        "python .repers/scripts/repers.py release-evidence --package --verify-roundtrip --json"
      ],
      "paths": [
        "scripts/release_evidence.py",
        "scripts/package_repers.py",
        "docs/contracts.md",
        "dist/repers-release-evidence.json"
      ],
      "verification": [
        "python .repers/scripts/repers.py release-evidence --package --verify-roundtrip --json"
      ]
    },
    {
      "id": "release-pack",
      "kind": "shipping-gate",
      "name": "Transferable Release Pack",
      "summary": "Builds one archive containing the installable RePERS package plus state, audit, benchmark, publish handoff, and remote bootstrap evidence.",
      "tags": [
        "release",
        "pack",
        "handoff",
        "package",
        "evidence",
        "offline",
        "publication"
      ],
      "commands": [
        "python .repers/scripts/repers.py release-pack --json"
      ],
      "paths": [
        "scripts/release_pack.py",
        "scripts/repers.py",
        "scripts/package_repers.py",
        "scripts/release_evidence.py",
        "scripts/publish_handoff.py",
        "docs/contracts.md"
      ],
      "verification": [
        "python .repers/scripts/repers.py release-pack --output <temp-dir> --json"
      ]
    },
    {
      "id": "release-pack-verify",
      "kind": "shipping-gate",
      "name": "Release Pack Archive Verification",
      "summary": "Verifies a transferred release-pack archive by checking the embedded manifest, required artifact roles, zip entries, and artifact SHA-256 values.",
      "tags": [
        "release",
        "pack",
        "verify",
        "archive",
        "handoff",
        "checksum",
        "offline"
      ],
      "commands": [
        "python .repers/scripts/repers.py release-pack-verify --archive <repers-release-pack.zip> --json"
      ],
      "paths": [
        "scripts/release_pack.py",
        "scripts/repers.py",
        "scripts/verify_all.py",
        "docs/contracts.md"
      ],
      "verification": [
        "python .repers/scripts/repers.py release-pack --output <temp-dir> --json",
        "python .repers/scripts/repers.py release-pack-verify --archive <temp-dir>/repers-release-pack.zip --json"
      ]
    },
    {
      "id": "publish-handoff",
      "kind": "shipping-gate",
      "name": "Publish Handoff Artifact",
      "summary": "Writes non-destructive JSON and Markdown handoff artifacts with remote, push, and draft PR commands derived from release evidence.",
      "tags": [
        "publish",
        "handoff",
        "remote",
        "push",
        "pull-request",
        "pr",
        "release",
        "evidence"
      ],
      "commands": [
        "python .repers/scripts/repers.py publish-handoff --json",
        "python .repers/scripts/repers.py publish-handoff --package --verify-roundtrip --remote-url <url> --json"
      ],
      "paths": [
        "scripts/publish_handoff.py",
        "scripts/release_evidence.py",
        "docs/contracts.md",
        "dist/repers-publish-handoff.json",
        "dist/repers-publish-handoff.md"
      ],
      "verification": [
        "python .repers/scripts/repers.py publish-handoff --package --verify-roundtrip --json"
      ]
    },
    {
      "id": "remote-bootstrap",
      "kind": "shipping-gate",
      "name": "Remote Bootstrap Artifact",
      "summary": "Writes provider-neutral remote setup evidence and can optionally apply git remote add before regenerating publish handoff artifacts.",
      "tags": [
        "remote",
        "bootstrap",
        "publish",
        "handoff",
        "git",
        "setup",
        "pr"
      ],
      "commands": [
        "python .repers/scripts/repers.py remote-bootstrap --remote-url <url> --json",
        "python .repers/scripts/repers.py remote-bootstrap --remote-url <url> --apply --json",
        "python .repers/scripts/repers.py remote-bootstrap-fixture --json"
      ],
      "paths": [
        "scripts/remote_bootstrap.py",
        "scripts/publish_handoff.py",
        "docs/contracts.md",
        "dist/repers-remote-bootstrap.json",
        "dist/repers-remote-bootstrap.md",
        "dist/repers-remote-bootstrap-fixture.json"
      ],
      "verification": [
        "python .repers/scripts/repers.py remote-bootstrap --remote-url https://example.invalid/repers.git --json",
        "python .repers/scripts/repers.py remote-bootstrap-fixture --json"
      ]
    },
    {
      "id": "publish-clone-fixture",
      "kind": "harness",
      "name": "Publish Clone Acceptance Fixture",
      "summary": "Copies the current RePERS worktree into a temporary source repo, pushes it to a local bare remote, clones it, and verifies RePERS from the clone.",
      "tags": [
        "publish",
        "clone",
        "bare-remote",
        "fixture",
        "acceptance",
        "verify-install",
        "state"
      ],
      "commands": [
        "python .repers/scripts/repers.py publish-clone-fixture --json"
      ],
      "paths": [
        "scripts/publish_clone_fixture.py",
        "scripts/repers.py",
        "scripts/verify_all.py",
        "scripts/objective_audit.py",
        "docs/contracts.md",
        "dist/repers-publish-clone-fixture.json"
      ],
      "verification": [
        "python .repers/scripts/repers.py publish-clone-fixture --json"
      ]
    },
    {
      "id": "source-install-fixture",
      "kind": "harness",
      "name": "Source Install Acceptance Fixture",
      "summary": "Proves a source or cloned RePERS repository can install itself into a fresh receiver Git repository with one CLI command and verify there.",
      "tags": [
        "install",
        "bootstrap",
        "source",
        "clone",
        "receiver",
        "fixture",
        "verify-install"
      ],
      "commands": [
        "python .repers/scripts/repers.py install --target <target-repo> --json",
        "python .repers/scripts/repers.py source-install-fixture --json"
      ],
      "paths": [
        "scripts/source_install_fixture.py",
        "scripts/install_repers.py",
        "scripts/repers.py",
        "scripts/verify_all.py",
        "scripts/objective_audit.py",
        "docs/contracts.md",
        "dist/repers-source-install-fixture.json"
      ],
      "verification": [
        "python .repers/scripts/repers.py source-install-fixture --json"
      ]
    },
    {
      "id": "verify-all",
      "kind": "shipping-gate",
      "name": "Sequential Local Verification",
      "summary": "Runs RePERS local gates sequentially with isolated temp outputs and writes a compact verify-all evidence artifact.",
      "tags": [
        "verify",
        "self-test",
        "sequential",
        "gates",
        "package",
        "smoke",
        "state",
        "race-safe"
      ],
      "commands": [
        "python .repers/scripts/repers.py verify-all --json"
      ],
      "paths": [
        "scripts/verify_all.py",
        "scripts/repers.py",
        "docs/contracts.md",
        "dist/repers-verify-all.json",
        "dist/repers-verify-all.md"
      ],
      "verification": [
        "python .repers/scripts/repers.py verify-all --json"
      ]
    },
    {
      "id": "receiver-fixture",
      "kind": "harness",
      "name": "Installed Receiver Acceptance Fixture",
      "summary": "Installs the packaged RePERS archive into a fresh Git repository and proves receiver commands: verify-install, doctor, bundle-status, capabilities, and fixture.",
      "tags": [
        "receiver",
        "install",
        "package",
        "acceptance",
        "doctor",
        "bundle-status",
        "capabilities",
        "fixture"
      ],
      "commands": [
        "python .repers/scripts/repers.py receiver-fixture --json"
      ],
      "paths": [
        "scripts/receiver_fixture.py",
        "scripts/install_repers.py",
        "scripts/package_repers.py",
        "tests/smoke_repers.py"
      ],
      "verification": [
        "python .repers/scripts/repers.py receiver-fixture --json"
      ]
    },
    {
      "id": "codex-plugin",
      "kind": "plugin",
      "name": "Codex Plugin Surface",
      "summary": "Plugin manifest and RePERS workflow skills that expose install, bug-hunt, release-pack, and drift-audit entrypoints to Codex.",
      "tags": [
        "plugin",
        "codex",
        "skills",
        "marketplace",
        "install",
        "bug-hunt",
        "release-pack",
        "drift"
      ],
      "commands": [
        "/plugin marketplace add coolsocket/repers",
        "/plugin install repers",
        "/repers-init",
        "/repers-bug-hunt",
        "/repers-release-pack",
        "/repers-sinkin"
      ],
      "paths": [
        ".codex-plugin/plugin.json",
        "skills/repers-init/SKILL.md",
        "skills/repers-bug-hunt/SKILL.md",
        "skills/repers-release-pack/SKILL.md",
        "skills/repers-sinkin/SKILL.md",
        "README.md"
      ],
      "verification": [
        "python C:/Users/Administrator/.codex/skills/.system/plugin-creator/scripts/validate_plugin.py .",
        "python .repers/scripts/repers.py capabilities --action search --query \"codex plugin skills\" --json"
      ]
    }
  ]
}